{% schema %}
{
  "name": "Banner",
  "tag": "section",
  "class": "banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "richtext",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "<p>Discover our latest arrivals and curated essentials.</p>"
    },
    {
      "type": "text",
      "id": "button_1",
      "label": "Button 1 label",
      "default": "Choose gift"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "richtext",
      "id": "message_text",
      "label": "Message text",
      "default": "<p>SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL</p>"
    },
    {
      "type": "text",
      "id": "button_2",
      "label": "Button 2 label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    }
  ],
  "blocks": [
    {
      "type": "banner-with-image",
      "name": "Banner with image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Banner title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA button label"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA button link"
        },
        {
          "type": "header",
          "content": "Content positioning"
        },
        {
          "type": "select",
          "id": "position",
          "label": "Position",
          "options": [
            {
              "value": "top",
              "label": "Top"
            },
            {
              "value": "bottom",
              "label": "Bottom"
            },
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "right",
              "label": "Right"
            },
            {
              "value": "center",
              "label": "Center"
            }
          ],
          "default": "bottom"
        },
        {
          "type": "select",
          "id": "position_type",
          "label": "Position type",
          "options": [
            {
              "value": "overlay",
              "label": "Overlay (on top of image)"
            },
            {
              "value": "side",
              "label": "Side (parallel to image)"
            }
          ],
          "default": "overlay"
        },
        {
          "type": "header",
          "content": "Mobile settings"
        },
        {
          "type": "checkbox",
          "id": "is_mobile",
          "label": "Mobile view",
          "default": false
        }
      ]
    }
  ]
}
{% endschema %}

<div class="banner-section">
  <div class="banner-section__header">
    {% if section.settings.logo != blank %}
      <div class="banner-section__logo-wrap">
        <img
          src="{{ section.settings.logo | image_url: width: 400 }}"
          alt="{{ section.settings.logo.alt | default: shop.name }}"
          class="banner-section__logo"
        >
      </div>
    {% endif %}
    {% if section.settings.announcement_text != blank %}
      <div class="banner-section__announcement">{{ section.settings.announcement_text }}</div>
    {% endif %}
    {% if section.settings.button_1 != blank and section.settings.button_1_link != blank %}
      {% render 'button',
        label: section.settings.button_1,
        url: section.settings.button_1_link,
        class: 'banner-section__button button--yellow'
      %}
    {% endif %}
  </div>

  <div class="banner-section__banners">
    {% for block in section.blocks %}
      {% if block.type == 'banner-with-image' %}
        {% render 'banner-with-image', block: block, section: section %}
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.message_text != blank %}
    <div class="banner-section__message">
      {{ section.settings.message_text }}
    </div>
  {% endif %}
  {% if section.settings.button_2 != blank and section.settings.button_2_link != blank %}
    <a href="{{ section.settings.button_2_link }}" class="banner-section__footer-button">
      {{ section.settings.button_2 }}
    </a>
  {% endif %}
</div>
