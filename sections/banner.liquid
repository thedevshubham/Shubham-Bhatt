{% schema %}
{
  "name": "Banner",
  "tag": "section",
  "class": "banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Discover our latest arrivals and curated essentials.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f7f3eb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32
    },
    {
      "type": "header",
      "content": "Hero overlay content"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero heading"
    },
    {
      "type": "richtext",
      "id": "hero_text",
      "label": "Hero text"
    },
    {
      "type": "text",
      "id": "hero_button_label",
      "label": "Hero button label"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Hero button link"
    }
  ]
}
{% endschema %}

<section
  class="banner-section"
  style="--banner-bg: {{ section.settings.background_color }}; --banner-text: {{ section.settings.text_color }}; --banner-padding-top: {{ section.settings.padding_block_start }}px; --banner-padding-bottom: {{ section.settings.padding_block_end }}px;"
>
  <div class="banner-section__inner">
    <div class="banner-section__header">
      {% if section.settings.logo != blank %}
        <div class="banner-section__logo-wrap">
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            alt="{{ section.settings.logo.alt | default: shop.name }}"
            class="banner-section__logo"
          >
        </div>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="banner-section__text">{{ section.settings.text }}</div>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="banner-section__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="banner-section__main">
      <!-- Image only banner -->
      <div class="banner-section__mobile-banner">
        {% render 'banner-hero', image: section.settings.banner_image %}
      </div>

      <!-- Image with text overlay and CTA -->
      <div class="banner-section__desktop-banner">
        {% render 'banner-hero',
          image: section.settings.banner_image,
          heading: section.settings.hero_heading,
          text: section.settings.hero_text,
          button_label: section.settings.hero_button_label,
          button_url: section.settings.hero_button_link
        %}
      </div>
    </div>
  </div>
</section>
