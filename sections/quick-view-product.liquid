{% schema %}
{
    "name":"Quick View Product",
    "settings":[]
}
{% endschema %}


<div class="quick-product">

    <div class="quick-product__image">

        {{
            product.featured_image
            | image_url: width: 800
            | image_tag
        }}

    </div>

    <div class="quick-product__info">

        <h2>{{ product.title }}</h2>

        <div class="price">

            {{ product.price | money }}

        </div>

        <div class="description">

            {{ product.description | strip_html | truncate: 180 }}

        </div>

        {% form 'product', product, class: 'quick-view-product-form' %}

            {% unless product.has_only_default_variant %}

                {% for option in product.options_with_values %}

                    <label>

                        {{ option.name }}

                    </label>

                    <select
                        name="options[{{ option.name }}]"
                        class="js-product-option"
                        data-option-index="{{ forloop.index0 }}"
                    >

                        {% for value in option.values %}

                            <option
                                {% if option.selected_value == value %}
                                    selected
                                {% endif %}
                            >
                                {{ value }}
                            </option>

                        {% endfor %}

                    </select>

                {% endfor %}

            {% endunless %}

            <input
                type="hidden"
                name="id"
                class="js-selected-variant-id"
                value="{{ product.selected_or_first_available_variant.id }}"
            >

            <button
                type="submit"
            >

                Add To Cart

            </button>

            <script type="application/json" class="js-product-json">
                {{ product | json }}
            </script>

        {% endform %}

    </div>

</div>
