{% comment %}
Flexible banner snippet with responsive layout
Mobile: Title and description above, CTA overlaid on image
Desktop: Title, description, CTA on left, image on right

Usage for simple banner:
{% render 'banner-hero', image: section.settings.banner_image %}

Usage for banner with overlay:
{% render 'banner-hero', 
  image: section.settings.banner_image,
  heading: section.settings.hero_heading,
  text: section.settings.hero_text,
  button_label: section.settings.hero_button_label,
  button_url: section.settings.hero_button_link
%}
{% endcomment %}

<div class="banner-hero">
  {% if image != blank %}
    <div class="banner-hero__wrapper">
      {% if heading != blank or text != blank %}
        <div class="banner-hero__content-wrapper">
          <div class="banner-hero__content">
            {% if heading != blank %}
              <h2 class="banner-hero__heading">{{ heading }}</h2>
            {% endif %}
            {% if text != blank %}
              <div class="banner-hero__text">{{ text }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
      
      <div class="banner-hero__image-wrapper">
        <img
          src="{{ image | image_url: width: 1600 }}"
          alt="{{ image.alt | default: 'Banner image' }}"
          class="banner-hero__image"
        >
        
        {% if heading != blank or text != blank or button_label != blank %}
          <div class="banner-hero__overlay">
            {% if button_label != blank and button_url != blank %}
              <a href="{{ button_url }}" class="banner-hero__button">
                {{ button_label }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="banner-hero__placeholder">
      <p>Banner image not set</p>
    </div>
  {% endif %}
</div>
